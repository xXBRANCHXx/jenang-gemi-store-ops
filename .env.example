JG_SHOPEE_INGEST_BASE_URL=https://api.jenanggemi.com
JG_SHOPEE_INGEST_SETUP_TOKEN=
JG_ADMIN_CODE_HASH=

# Single-account fallback. Keep this set while migrating.
JG_SHOPEE_ACCOUNT=jenang-gemi-shopee

# Add only after each account is authorized and tested in the ingest setup page.
JG_SHOPEE_ACCOUNTS=jenang-gemi-shopee,zero-shopee,zfit-shopee

# Optional marketplace sources. Unconfigured accounts fail independently and do not block working sources.
# Tokopedia should flow through TikTok unified commerce, not a separate Store Ops source.
JG_TIKTOK_ACCOUNTS=jenang-gemi-tiktok,zero-tiktok,zfit-tiktok

# Advanced override, if you want one explicit list instead of per-platform lists:
# JG_MARKETPLACE_SOURCES=shopee:jenang-gemi-shopee,shopee:zero-shopee,tiktok:jenang-gemi-tiktok

# Required for token-authenticated Hard Set activation, website-order ingest, labels, and callbacks.
JG_STORE_OPS_WEBSITE_TOKEN=
JG_EXECUTIVE_DASHBOARD_URL=https://admin.jenanggemi.com
